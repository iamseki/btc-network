BTC_NETWORK_POSTGRES_URL=postgresql://btc_network_crawler:CHANGE_ME@127.0.0.1:5432/btc_network
BTC_NETWORK_POSTGRES_MAX_CONNECTIONS=16
BTC_NETWORK_CRAWLER_MAX_CONCURRENCY=2000
BTC_NETWORK_CRAWLER_MAX_IN_FLIGHT_CONNECTS=256
BTC_NETWORK_CRAWLER_MAX_TRACKED_NODES=250000
BTC_NETWORK_CRAWLER_CONNECT_MAX_ATTEMPTS=5
BTC_NETWORK_CRAWLER_CONNECT_RETRY_BACKOFF_MS=250
BTC_NETWORK_CRAWLER_CONNECT_TIMEOUT_SECS=30
BTC_NETWORK_CRAWLER_IO_TIMEOUT_SECS=20
BTC_NETWORK_MMDB_ASN_PATH=/var/lib/btc-network/mmdb/GeoLite2-ASN.mmdb
BTC_NETWORK_MMDB_COUNTRY_PATH=/var/lib/btc-network/mmdb/GeoLite2-Country.mmdb
# BTC_NETWORK_CRAWLER_TOR_SOCKS5_ADDR=127.0.0.1:9050

