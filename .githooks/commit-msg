#!/usr/bin/env bash

set -euo pipefail

message_file="${1:-}"
if [[ -z "$message_file" ]]; then
  echo "usage: $0 <commit-message-file>" >&2
  exit 2
fi

subject="$(sed -n '1p' "$message_file")"
repo_root="$(git rev-parse --show-toplevel)"

"$repo_root/scripts/validate-semantic-subject.sh" "commit subject" "$subject"
